# Flask
FLASK_ENV=development
FLASK_APP=wsgi.py
FLASK_DEBUG=1
SECRET_KEY=change-me-to-a-random-secret-key

# Database (SQLite for local dev; use postgresql:// in production)
DATABASE_URL=sqlite:///elcorp_dev.db

# Redis
REDIS_URL=redis://localhost:6379/0

# Celery
CELERY_BROKER_URL=redis://localhost:6379/1
CELERY_RESULT_BACKEND=redis://localhost:6379/2

# JWT
JWT_SECRET_KEY=change-me-to-a-random-jwt-secret
JWT_ACCESS_TOKEN_EXPIRES=3600
JWT_REFRESH_TOKEN_EXPIRES=2592000

# Encryption
ENCRYPTION_KEY=change-me-base64-encoded-32-byte-key

# KYC / File uploads
UPLOAD_FOLDER=uploads
MAX_CONTENT_LENGTH=16777216
ALLOWED_EXTENSIONS=png,jpg,jpeg,pdf

# CORS
CORS_ORIGINS=http://localhost:3000,http://localhost:5173

# Rate Limiting
RATELIMIT_DEFAULT=100/hour
RATELIMIT_STORAGE_URI=redis://localhost:6379/3

# Monitoring
PROMETHEUS_ENABLED=true
LOG_LEVEL=DEBUG

# Sandbox Payment Gateway (mock)
PAYMENT_GATEWAY_URL=http://localhost:5000/api/v1/sandbox/gateway
PAYMENT_GATEWAY_API_KEY=sandbox-test-key

# Email (optional for MVP)
MAIL_SERVER=localhost
MAIL_PORT=1025
MAIL_USE_TLS=false
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_DEFAULT_SENDER=noreply@elcorp.na
